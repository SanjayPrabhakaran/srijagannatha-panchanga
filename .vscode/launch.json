{
    "configurations": [
        {
            "name": "Attach to Chrome",
            "port": 9222,
            "request": "attach",
            "type": "chrome",
            "webRoot": "${workspaceFolder}"
        },
        {
            "type": "firefox",
            "request": "launch",
            "name": "Launch Firefox on SJP.html",
            "url": "${workspaceFolder}/SJPv6/www/SJP.html",
            "webRoot": "${workspaceFolder}",
            "reAttach": true,
            //"firefoxExecutable" : "/snap/firefox/7672/usr/lib/firefox/firefox"
            "firefoxExecutable": "/snap/firefox/current/usr/lib/firefox/firefox"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome on SJP.html",
            "url": "file://${workspaceFolder}/SJPv6/www/SJP.html",
            "webRoot": "${workspaceFolder}",
            //"firefoxExecutable" : "/snap/firefox/7672/usr/lib/firefox/firefox"
            "runtimeExecutable": "/var/lib/flatpak/exports/bin/com.google.Chrome",
            "runtimeArgs": [
                "--remote-debugging-port=9222",
                "--allow-file-access-from-files"
            ],
        }
    ]
}